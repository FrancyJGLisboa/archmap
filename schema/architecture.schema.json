{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/FrancyJGLisboa/archmap/schema/architecture.schema.json",
  "title": "archmap architecture v1",
  "type": "object",
  "required": ["archmap_version", "name", "generated", "layers", "components", "flows"],
  "properties": {
    "archmap_version": {"const": "1"},
    "name": {"type": "string", "minLength": 1},
    "description": {"type": "string"},
    "generated": {
      "type": "object",
      "required": ["commit_sha", "branch", "date"],
      "properties": {
        "commit_sha": {"type": "string", "pattern": "^[0-9a-f]{7,40}$"},
        "branch": {"type": "string"},
        "date": {"type": "string"},
        "tool_version": {"type": "string"}
      }
    },
    "layers": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "required": ["id", "name", "order"],
        "properties": {
          "id": {"type": "string"}, "name": {"type": "string"}, "order": {"type": "number"}
        }
      }
    },
    "components": {
      "type": "array", "minItems": 5,
      "items": {
        "type": "object", "required": ["id", "name", "layer", "path", "description"],
        "properties": {
          "id": {"type": "string"}, "name": {"type": "string"},
          "layer": {"type": "string", "description": "id of a declared layer"},
          "path": {"type": "string", "description": "repo-relative, must exist, never \".\""},
          "description": {"type": "string"}, "tech": {"type": "string"},
          "dependencies": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "external_services": {
      "type": "array",
      "items": {
        "type": "object", "required": ["id", "name"],
        "properties": {
          "id": {"type": "string"}, "name": {"type": "string"},
          "description": {"type": "string"}, "url": {"type": "string"}
        }
      }
    },
    "flows": {
      "type": "array", "minItems": 2,
      "items": {
        "type": "object", "required": ["id", "name", "steps"],
        "properties": {
          "id": {"type": "string"}, "name": {"type": "string"}, "description": {"type": "string"},
          "steps": {
            "type": "array", "minItems": 1,
            "items": {
              "type": "object", "required": ["from", "to"],
              "properties": {
                "from": {"type": "string"}, "to": {"type": "string"}, "label": {"type": "string"}
              }
            }
          }
        }
      }
    },
    "entry_points": {
      "type": "array",
      "items": {
        "type": "object", "required": ["component"],
        "properties": {"component": {"type": "string"}, "description": {"type": "string"}}
      }
    },
    "x_extensions": {"type": "object", "description": "free-form, ignored by viewer and validator"}
  }
}
